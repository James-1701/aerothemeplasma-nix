Subject: [PATCH] Remove assertion failure on empty dialogs

This will likely be temporary as to give enough time to sort out all
instances of this in AeroShell.
---
 src/plasmaquick/dialog.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/plasmaquick/dialog.cpp b/src/plasmaquick/dialog.cpp
index 5a1c67b3c..853a5539e 100644
--- a/src/plasmaquick/dialog.cpp
+++ b/src/plasmaquick/dialog.cpp
@@ -617,7 +617,7 @@ void DialogPrivate::syncToMainItemSize()
     }
     if (mainItem->width() <= 0 || mainItem->height() <= 0) {
         qmlWarning(q) << "trying to show an empty dialog";
-        Q_ASSERT(false);
+        //Q_ASSERT(false);
     }
 
     updateTheme();
